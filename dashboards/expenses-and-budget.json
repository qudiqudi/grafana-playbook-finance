      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": "Budget|Actual" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] }, { "matcher": { "id": "byName", "options": "Variance" }, "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }, { "id": "color", "value": { "mode": "continuous-GrYlRd" } }] }] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [{ "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "finance-postgres" }, "format": "table", "rawSql": "SELECT b.category AS \"Category\", b.budgeted AS \"Budget\", COALESCE(a.actual, 0) AS \"Actual\", COALESCE(a.actual, 0) - b.budgeted AS \"Variance\" FROM budgets b LEFT JOIN (SELECT category, SUM(amount) AS actual FROM expenses WHERE date_trunc('month', incurred_at) = date_trunc('month', CURRENT_DATE) GROUP BY 1) a ON a.category = b.category WHERE b.period_month = date_trunc('month', CURRENT_DATE)::date ORDER BY b.budgeted DESC;" }]
