    {
      "type": "timeseries",
      "title": "Budget vs Actual (Monthly Total)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "finance-postgres" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "auto" }, "color": { "mode": "palette-classic" } }, "overrides": [{ "matcher": { "id": "byName", "options": "Budget" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 6] } }] }, { "matcher": { "id": "byName", "options": "Actual" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "finance-postgres" }, "format": "table", "rawSql": "SELECT m AS time, actual AS \"Actual\", budget AS \"Budget\" FROM (SELECT date_trunc('month', incurred_at)::date AS m, SUM(amount) AS actual FROM expenses GROUP BY 1) e FULL JOIN (SELECT period_month AS m, SUM(budgeted) AS budget FROM budgets GROUP BY 1) b USING (m) WHERE $__timeFilter(m) ORDER BY m;" }]
    },
    {
      "type": "table",
