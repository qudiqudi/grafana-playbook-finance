      "targets": [{ "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "finance-postgres" }, "format": "table", "rawSql": "SELECT bucket AS \"Aging Bucket\", SUM(amount) AS \"Outstanding\" FROM (SELECT amount, CASE WHEN CURRENT_DATE - due_date <= 0 THEN 'Current' WHEN CURRENT_DATE - due_date <= 30 THEN '1-30 days' WHEN CURRENT_DATE - due_date <= 60 THEN '31-60 days' WHEN CURRENT_DATE - due_date <= 90 THEN '61-90 days' ELSE '90+ days' END AS bucket, CASE WHEN CURRENT_DATE - due_date <= 0 THEN 0 WHEN CURRENT_DATE - due_date <= 30 THEN 1 WHEN CURRENT_DATE - due_date <= 60 THEN 2 WHEN CURRENT_DATE - due_date <= 90 THEN 3 ELSE 4 END AS sort FROM invoices WHERE status IN ('open','overdue')) t GROUP BY bucket, sort ORDER BY sort;" }]
